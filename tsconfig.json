{
	"compilerOptions": {
		"esModuleInterop": true,
		"lib": ["ES2020"],
		"module": "CommonJS",
		"noEmit": true,
		"outDir": "lib",
		"moduleResolution": "node",
		"rootDir": "src",
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"target": "ES2020",
		"types": ["node", "vitest/globals"]
	},
	"exclude": ["node_modules", "lib", "example", "tests", "vitest.config.mts"]
}
